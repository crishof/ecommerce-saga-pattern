# Variables de entorno de ejemplo. Copiar a .env y ajustar si es necesario.
# En docker-compose.yml los valores por defecto ya apuntan a los nombres de
# servicio de la red interna, por lo que este archivo es solo informativo.

# URLs de infraestructura (vistas desde cada contenedor)
CONFIG_SERVER_URL=http://config-server:8889
EUREKA_URL=http://discovery-server:8762/eureka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Puertos de PostgreSQL dentro de la red (siempre 5432); el mapeo externo
# 5461-5467 está definido en docker-compose.yml.
DB_PORT_IDENTITY=5432
DB_PORT_CATALOG=5432
DB_PORT_ORDER=5432
DB_PORT_PAYMENT=5432
DB_PORT_INVENTORY=5432
DB_PORT_NOTIFICATION=5432
DB_PORT_SAGA=5432

# Simulación del gateway de pagos (payment-service)
APP_PAYMENTS_FAILURE_RATE=0.15
APP_PAYMENTS_PROCESSING_DELAY_MS=200

# Timeout de la saga (saga-orchestrator-service)
APP_SAGA_TIMEOUT_SECONDS=30
APP_SAGA_POLL_INTERVAL_MS=5000
